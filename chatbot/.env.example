NHS_CORPUS_PATH=./data/nhs_conditions.json
MEDWASLA_CORPUS_PATH=./data/medwasla_knowledge.json

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=elixpo/llamamedicine

EMBEDDING_MODEL=multi-qa-MiniLM-L6-cos-v1

TOP_K=3
SIMILARITY_THRESHOLD=0.16

TEMPERATURE=0.2
MAX_TOKENS=256
CONTEXT_SIZE=4096

FLASK_HOST=0.0.0.0
FLASK_PORT=3000
FLASK_DEBUG=True

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>
DATABASE_NAME=medwasla
ENABLE_DATABASE=True

# Must match the INTERNAL_API_SECRET in backend/.env exactly — without
# it, the Express->Flask auth check in app.py is skipped entirely, and
# /chat can be called directly with any user_id.
INTERNAL_API_SECRET=